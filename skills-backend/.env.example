# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=3303
NODE_ENV=development

# Provider fallbacks
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Omni shared compatible gateway bootstrap
# One shared provider/base/key can feed the default slots.
# Then only set slot-level MODEL ids unless you need per-slot overrides.
OMNI_DEFAULT_PROVIDER=openai_compatible
OMNI_DEFAULT_BASE_URL=https://ai.1seey.com/v1
OMNI_DEFAULT_API_KEY=your_compatible_api_key_here
OMNI_DEFAULT_APP_ID=suzhi

# Default slots
OMNI_LANGUAGE_MODEL=Kimi-K2.5
OMNI_MULTIMODAL_MODEL=Kimi-K2.5

# Optional slot-level overrides
# OMNI_LANGUAGE_PROVIDER=openai_compatible
# OMNI_LANGUAGE_BASE_URL=https://ai.1seey.com/v1
# OMNI_LANGUAGE_API_KEY=your_language_slot_key_here
# OMNI_MULTIMODAL_PROVIDER=openai_compatible
# OMNI_MULTIMODAL_BASE_URL=https://ai.1seey.com/v1
# OMNI_MULTIMODAL_API_KEY=your_multimodal_slot_key_here

# Optional role-level overrides
# OMNI_ROLE_NODE_WRITER_MODEL=your_custom_model_id
# OMNI_ROLE_VISION_READER_MODEL=your_custom_multimodal_model_id

# Storage
UPLOAD_DIR=./uploads
PDF_DIR=./uploads/pdfs
FIGURE_DIR=./uploads/figures

# Logging
LOG_LEVEL=info
