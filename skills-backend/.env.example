# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=3303
NODE_ENV=development

# Provider fallbacks
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Omni shared BigModel/GLM bootstrap
# Defaults use Zhipu BigModel API (智谱 GLM-5 "mydamoxing" requirement via existing bigmodel provider).
# NOTE: If a custom 'mydamoxing' gateway is intended, override OMNI_DEFAULT_BASE_URL explicitly.
OMNI_DEFAULT_PROVIDER=bigmodel
OMNI_DEFAULT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OMNI_DEFAULT_API_KEY=your_bigmodel_api_key_here
OMNI_DEFAULT_APP_ID=

# Default slots
OMNI_LANGUAGE_MODEL=glm-5
OMNI_MULTIMODAL_MODEL=glm-4.6v

# Optional slot-level overrides
# OMNI_LANGUAGE_PROVIDER=openai_compatible
# OMNI_LANGUAGE_BASE_URL=https://ai.1seey.com/v1
# OMNI_LANGUAGE_API_KEY=your_language_slot_key_here
# OMNI_MULTIMODAL_PROVIDER=openai_compatible
# OMNI_MULTIMODAL_BASE_URL=https://ai.1seey.com/v1
# OMNI_MULTIMODAL_API_KEY=your_multimodal_slot_key_here

# Optional role-level overrides
# OMNI_ROLE_NODE_WRITER_MODEL=your_custom_model_id
# OMNI_ROLE_VISION_READER_MODEL=your_custom_multimodal_model_id

# Storage
UPLOAD_DIR=./uploads
PDF_DIR=./uploads/pdfs
FIGURE_DIR=./uploads/figures

# Logging
LOG_LEVEL=info
