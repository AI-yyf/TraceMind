{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["shared/*"],
      "@engine/*": ["engine/*"],
      "@runtime/*": ["runtime/*"]
    }
  },
  "include": [
    "src/**/*",
    "shared/**/*",
    "engine/**/*",
    "runtime/**/*",
    "skill-packs/**/*",
    "topic-config/**/*",
    "cli.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "scripts/**/*",
    "tests/**/*",
    "output/**/*",
    "uploads/**/*",
    "prisma/**/*.db"
  ]
}
