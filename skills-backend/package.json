{
  "name": "@tracemind/backend",
  "version": "1.0.0",
  "description": "TraceMind research API, orchestration, and model gateway",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node -e \"require('fs').rmSync('dist',{ recursive: true, force: true })\" && tsc && node scripts/copy-topic-config-assets.mjs",
    "start": "node dist/src/server.js",
    "test": "node --import tsx --test src/tests/**/*.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/scripts/seed.ts",
    "scheduler:start": "tsx src/scripts/scheduler-cli.ts",
    "topic:generate": "tsx src/scripts/topic-generate.ts",
    "topic:reset": "tsx src/scripts/reset-topics.ts",
    "topic:clear-runtime": "tsx src/scripts/clear-topic-runtime.ts",
    "suzhi:prepare-runtime": "tsx src/scripts/prepare-suzhi-runtime.ts",
    "clean:content": "tsx scripts/clean-generated-content.ts",
    "topic:extract-pdfs": "tsx src/scripts/extract-topic-pdfs.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.24.1",
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.2.0",
    "ws": "^8.16.0",
    "uuid": "^9.0.1",
    "date-fns": "^3.0.0",
    "p-retry": "^6.2.0",
    "p-timeout": "^6.1.2",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.33.1",
    "node-cron": "^3.0.3",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "redis": "^4.6.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "prisma": "^5.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
