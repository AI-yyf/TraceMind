generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model figures {
  id        String   @id
  paperId   String
  number    Int
  caption   String
  page      Int
  imagePath String
  analysis  String?
  createdAt DateTime @default(now())
  papers    papers   @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model formulas {
  id        String   @id
  paperId   String
  number    String
  latex     String
  rawText   String
  page      Int
  createdAt DateTime @default(now())
  papers    papers   @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model model_configs {
  id            String          @id
  modelId       String          @unique
  name          String
  provider      String
  model         String
  apiKey        String
  baseUrl       String?
  parameters    String
  capabilities  String
  enabled       Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  task_mappings task_mappings[]

  @@index([provider])
}

model node_papers {
  id             String         @id
  nodeId         String
  paperId        String
  order          Int
  papers         papers         @relation(fields: [paperId], references: [id], onDelete: Cascade)
  research_nodes research_nodes @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([nodeId, paperId])
  @@index([paperId])
  @@index([nodeId])
}

model paper_candidate_pool {
  id                String    @id
  topicId           String
  paperId           String?
  title             String
  authors           String?
  published         DateTime?
  summary           String?
  arxivUrl          String?
  pdfUrl            String?
  openAlexId        String?
  semanticScholarId String?
  status            String    @default("candidate")
  confidence        Float     @default(0.5)
  candidateType     String?
  discoverySource   String?
  discoveryChannels String?
  queryHits         String?
  rejectReason      String?
  rejectFilter      String?
  rejectScore       Float?
  snowballParentId  String?
  snowballDepth     Int?
  snowballType      String?
  createdAt         DateTime  @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?
  reviewDecision    String?
  reviewComment     String?
  topics            topics    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([discoverySource])
  @@index([confidence])
  @@index([status])
  @@index([topicId])
}

model paper_sections {
  id                 String @id
  paperId            String
  sourceSectionTitle String
  editorialTitle     String
  paragraphs         String
  order              Int
  papers             papers @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model papers {
  id             String           @id
  topicId        String
  title          String
  titleZh        String
  titleEn        String?
  authors        String
  published      DateTime
  summary        String
  explanation    String?
  arxivUrl       String?
  pdfUrl         String?
  pdfPath        String?
  citationCount  Int?
  coverPath      String?
  figurePaths    String
  tablePaths     String
  status         String           @default("candidate")
  tags           String
  contentMode    String           @default("editorial")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  figures        figures[]
  formulas       formulas[]
  node_papers    node_papers[]
  paper_sections paper_sections[]
  topics         topics           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  research_nodes research_nodes[]
  tables         tables[]

  @@index([published])
  @@index([status])
  @@index([topicId])
}

model research_nodes {
  id                  String        @id
  topicId             String
  stageIndex          Int
  nodeLabel           String
  nodeSubtitle        String?
  nodeSummary         String
  nodeExplanation     String?
  nodeCoverImage      String?
  status              String        @default("provisional")
  isMergeNode         Boolean       @default(false)
  provisional         Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime
  primaryPaperId      String?
  fullContent         String?
  fullArticleFlow     String?
  editorialPromptHash String?
  node_papers         node_papers[]
  papers              papers?       @relation(fields: [primaryPaperId], references: [id])
  topics              topics        @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([stageIndex])
  @@index([topicId])
}

model research_pipeline_states {
  id        String   @id
  topicId   String   @unique
  state     String
  updatedAt DateTime

  @@index([topicId])
}

model research_sessions {
  id           String    @id
  topicIds     String
  mode         String    @default("full")
  status       String    @default("running")
  currentStage String?
  progress     Float     @default(0)
  logs         String
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  error        String?

  @@index([status])
}

model research_world_snapshots {
  id          String   @id
  topicId     String   @unique
  world       String
  fingerprint String?
  updatedAt   DateTime

  @@index([topicId])
}

model system_configs {
  id        String   @id
  key       String   @unique
  value     String
  updatedAt DateTime
}

model tables {
  id        String   @id
  paperId   String
  number    Int
  caption   String
  page      Int
  headers   String
  rows      String
  rawText   String
  createdAt DateTime @default(now())
  papers    papers   @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model task_mappings {
  id              String        @id
  taskName        String        @unique
  modelId         String
  fallbackModelId String?
  model_configs   model_configs @relation(fields: [modelId], references: [modelId], onDelete: Cascade)
}

model topic_guidance_ledgers {
  id         String   @id
  topicId    String   @unique
  directives String
  updatedAt  DateTime

  @@index([topicId])
}

model topic_session_memories {
  id        String   @id
  topicId   String   @unique
  events    String
  summary   String?
  updatedAt DateTime

  @@index([topicId])
}

model topic_stages {
  id            String  @id
  topicId       String
  order         Int
  name          String
  nameEn        String?
  description   String?
  descriptionEn String?
  topics        topics  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model topics {
  id                   String                 @id
  nameZh               String
  nameEn               String?
  focusLabel           String?
  summary              String?
  description          String?
  language             String                 @default("zh")
  status               String                 @default("active")
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  exportedToZoteroAt   DateTime?
  zoteroCollectionKey  String?
  paper_candidate_pool paper_candidate_pool[]
  papers               papers[]
  research_nodes       research_nodes[]
  topic_stages         topic_stages[]

  @@index([language])
  @@index([status])
}

model zotero_config {
  id        String   @id @default("default")
  userId    String
  apiKey    String
  username  String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}
