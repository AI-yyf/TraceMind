    "titleZh": "End to End Learning for Self-Driving Cars",
    "titleEn": "End to End Learning for Self-Driving Cars"
  },
  "1803.08554": {
    "id": "1803.08554",
    "version": "v1",
    "title": "Bio-inspired Machine Learning",
    "summary": "Neuronal Circuit Policies 是这条主线中把生物结构重新转化为可训练控制模型的早期代表，后续液态网络与连续时间模型持续在推进这一路线。",
