  "2210.03629": {
    "id": "2210.03629",
    "version": "v3",
    "title": "ReAct: Synergizing Reasoning and Acting in Language Models",
    "summary": "ReAct 给现代 Agent 设定了“推理-行动-观察”闭环骨架，之后 Toolformer、Reflexion、CAMEL、AutoGen 分别在工具学习、记忆和多智能体协作上继续补齐。",
    "published": "2022-10-07T00:00:00.000Z",
    "authors": [
      "Shunyu Yao",
      "Jeffrey Zhao",
      "Dian Yu",
      "Nan Du",
      "Izhak Shafran",
      "Karthik Narasimhan",
      "Yuan Cao"
    ],
    "arxivUrl": "https://arxiv.org/abs/2210.03629",
    "pdfUrl": "https://arxiv.org/pdf/2210.03629.pdf",
    "titleZh": "ReAct: Synergizing Reasoning and Acting in Language Models",
    "titleEn": "ReAct: Synergizing Reasoning and Acting in Language Models"
  },
  "1604.07316": {
    "id": "1604.07316",
    "version": "v1",
    "title": "End to End Learning for Self-Driving Cars",
    "summary": "它用“直接从像素输入学习转向控制”的方式重新界定了现代端到端自动驾驶问题，并把手工模块栈整体拿掉。",
    "published": "2016-04-25T00:00:00.000Z",
