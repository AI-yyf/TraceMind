{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@generated/*": ["./generated/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/components/BatchResearchLauncher.tsx",
    "src/components/OnboardingGuide.tsx",
    "src/components/PromptTemplateManager.tsx",
    "src/components/ResearchLauncher.tsx",
    "src/components/SettingsPanel.tsx",
    "src/components/TaskScheduler.tsx",
    "src/components/UI",
    "src/components/Paper",
    "src/components/paper",
    "src/components/visualization",
    "src/data/topicDisplay.ts",
    "src/hooks/useConfig.ts",
    "src/hooks/useDataBridge.ts",
    "src/hooks/useDataLayer.ts",
    "src/hooks/useTimelineData.ts",
    "src/pages/CreateTopicPage.tsx",
    "src/pages/NodeDetailPage.tsx",
    "src/pages/PaperPage.tsx",
    "src/pages/ResearchPage.tsx",
    "src/pages/TodayPage.tsx",
    "src/pages/TopicManagerPage.tsx"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
